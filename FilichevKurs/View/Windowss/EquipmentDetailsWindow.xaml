<Window x:Class="FilichevKurs.View.Windowss.EquipmentDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FilichevKurs.View.Windowss"
        mc:Ignorable="d"
        Title="EquipmentDetailsWindow" Height="700" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60*"/>
            <ColumnDefinition Width="40*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ: Фотография из БД -->
        <Border Grid.Column="0" Background="#1A1A2E" Margin="0">
            <Grid>
                <!-- Контейнер для фото 16:9 -->
                <Viewbox Stretch="Uniform" Margin="40">
                    <Border Width="1600" Height="900" Background="#2D3748" CornerRadius="8">

                        <!-- Image для отображения фото из БД -->
                        <Image x:Name="imgEquipment" 
                               Stretch="Uniform" 
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                    </Border>
                </Viewbox>

                <!-- Кнопка закрыть -->
                <Button x:Name="btnCloseLeft" Content="&#10005;" 
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       Margin="20" Padding="15" 
                       Background="#E94560" Foreground="White"
                       BorderThickness="0" FontSize="16"
                       Click="btnClose_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                   CornerRadius="50" 
                                   Width="40" Height="40">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                 VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Название техники поверх фото -->
                <Border VerticalAlignment="Bottom" 
                       Background="#1A1A2E" 
                       Opacity="0.9"
                       Padding="30,20">
                    <TextBlock x:Name="txtPhotoTitle" 
                              FontSize="28" 
                              FontWeight="Bold" 
                              Foreground="White"/>
                </Border>
            </Grid>
        </Border>

        <!-- ПРАВАЯ ЧАСТЬ: Описание (без изменений) -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Background="White" Height="424">

                <!-- Заголовок -->
                <Border Background="#F8F9FA" Padding="30" Height="19">
                    <StackPanel>
                        <TextBlock x:Name="txtType" 
                                  FontSize="12" 
                                  FontWeight="SemiBold"
                                  Foreground="#E94560"
                                  Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtName" 
                                  FontSize="28" 
                                  FontWeight="Bold" 
                                  Foreground="#1A1A2E"
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Основные характеристики -->
                <StackPanel Margin="30">
                    <TextBlock Text="Основные характеристики" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#1A1A2E"
                              Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,15">
                            <TextBlock Text="Производитель" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtManufacturer" 
                                      FontSize="14" FontWeight="SemiBold" 
                                      Foreground="#1A1A2E"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
                            <TextBlock Text="Год производства" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtYear" 
                                      FontSize="14" FontWeight="SemiBold" 
                                      Foreground="#1A1A2E"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,20,15">
                            <TextBlock Text="Боевая масса" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtWeight" 
                                      FontSize="14" FontWeight="SemiBold" 
                                      Foreground="#1A1A2E"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                            <TextBlock Text="Экипаж" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtCrew" 
                                      FontSize="14" FontWeight="SemiBold" 
                                      Foreground="#1A1A2E"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,20,15">
                            <TextBlock Text="Габариты (Д×Ш×В)" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtDimensions" 
                                      FontSize="14" FontWeight="SemiBold" 
                                      Foreground="#1A1A2E"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,15">
                            <TextBlock Text="Максимальная скорость" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtSpeed" 
                                      FontSize="14" FontWeight="SemiBold" 
                                      Foreground="#1A1A2E"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
                            <TextBlock Text="Двигатель" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtEngine" 
                                      FontSize="14" FontWeight="SemiBold" 
                                      Foreground="#1A1A2E"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border Background="#F8F9FA" Height="1" Margin="30,0"/>

                <!-- Бронирование -->
                <StackPanel Margin="30">
                    <TextBlock Text="Бронирование" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#1A1A2E"
                              Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtArmor" 
                              FontSize="14" 
                              Foreground="#4A5568"
                              TextWrapping="Wrap"
                              LineHeight="24"/>
                </StackPanel>

                <Border Background="#F8F9FA" Height="1" Margin="30,0"/>

                <!-- Вооружение -->
                <StackPanel Margin="30">
                    <TextBlock Text="Вооружение" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#1A1A2E"
                              Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtArmament" 
                              FontSize="14" 
                              Foreground="#4A5568"
                              TextWrapping="Wrap"
                              LineHeight="24"/>
                </StackPanel>

                <Border Background="#F8F9FA" Height="1" Margin="30,0"/>

                <!-- Описание -->
                <StackPanel Margin="30">
                    <TextBlock Text="Описание" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#1A1A2E"
                              Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtDescription" 
                              FontSize="14" 
                              Foreground="#4A5568"
                              TextWrapping="Wrap"
                              LineHeight="24"/>
                </StackPanel>

                <Border Background="#F8F9FA" Height="1" Margin="30,0"/>

                <!-- Статус в музее -->
                <StackPanel Margin="30">
                    <TextBlock Text="Состояние в музее" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#1A1A2E"
                              Margin="0,0,0,15"/>

                    <Border x:Name="borderStatus" 
                           Background="#F0FDF4" 
                           BorderBrush="#16A34A" 
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="15"
                           Margin="0,0,0,15">
                        <TextBlock x:Name="txtStatus" 
                                  FontSize="16" 
                                  FontWeight="SemiBold"
                                  Foreground="#16A34A"/>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Инв. номер: " 
                                  FontSize="14" Foreground="#5F6368"/>
                        <TextBlock x:Name="txtInventory" 
                                  FontSize="14" FontWeight="SemiBold" 
                                  Foreground="#1A1A2E"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Поступила: " 
                                  FontSize="14" Foreground="#5F6368"/>
                        <TextBlock x:Name="txtArrivalDate" 
                                  FontSize="14" FontWeight="SemiBold" 
                                  Foreground="#1A1A2E"/>
                    </StackPanel>
                </StackPanel>

                <!-- Кнопка закрыть -->
                <Button x:Name="btnCloseBottom" Content="Закрыть" 
                       Margin="30" Padding="20,12"
                       Background="#1A1A2E" Foreground="White"
                       BorderThickness="0" FontSize="14"
                       FontWeight="SemiBold"
                       Click="btnClose_Click" Cursor="Hand"
                       HorizontalAlignment="Stretch">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                   CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>