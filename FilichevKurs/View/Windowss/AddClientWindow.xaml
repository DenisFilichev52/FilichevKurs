<Window x:Class="FilichevKurs.View.Windowss.AddClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FilichevKurs.View.Windowss"
        mc:Ignorable="d"
        Title="Добавление клиента" Height="500" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Background="#1A237E" Height="50" VerticalAlignment="Top">
            <TextBlock Text="НОВЫЙ КЛИЕНТ" 
                       Foreground="White" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="15,0"/>
        </Border>

        <StackPanel Margin="20,70,20,20">

            <TextBlock Text="Фамилия *" FontWeight="Bold"/>
            <TextBox x:Name="txtLastName" Padding="" Margin="0,5,0,10"/>

            <TextBlock Text="Имя *" FontWeight="Bold"/>
            <TextBox x:Name="txtFirstName" Padding="8" Margin="0,5,0,10"/>

            <TextBlock Text="Отчество" FontWeight="Bold"/>
            <TextBox x:Name="txtMiddleName" Padding="8" Margin="0,5,0,10"/>

            <TextBlock Text="Телефон" FontWeight="Bold"/>
            <TextBox x:Name="txtPhone" Padding="8" Margin="0,5,0,10"/>

            <TextBlock Text="Email" FontWeight="Bold"/>
            <TextBox x:Name="txtEmail" Padding="8" Margin="0,5,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Сохранить" 
                        Background="#E91E63"
                        Foreground="White"
                        Padding="25,10"
                        Margin="0,0,10,0"
                        Click="SaveButton_Click"/>

                <Button Content="Отмена" 
                        Background="Gray"
                        Foreground="White"
                        Padding="25,10"
                        Click="CancelButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
