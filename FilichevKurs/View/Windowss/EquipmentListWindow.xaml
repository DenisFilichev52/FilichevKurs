<Window x:Class="FilichevKurs.View.Windowss.EquipmentListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FilichevKurs.View.Windowss"
        mc:Ignorable="d"
        Title="EquipmentListWindow" Height="900" Width="1500">
    <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#1A1A2E" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ЭКСПОНАТЫ ВОЕННОЙ ТЕХНИКИ" 
                          FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <Button Grid.Column="1" x:Name="btnCloseTop" Content="&#10005;" 
                       Background="Transparent" Foreground="White" 
                       BorderThickness="0" FontSize="20" Click="btnClose_Click"/>
                </Grid>
            </Border>

            <!-- Панель фильтров и сортировки -->
            <Grid Grid.Row="1" Background="White">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Фильтр по типу -->
                <TextBlock Grid.Column="0" Text="Тип техники:" VerticalAlignment="Center" 
                      FontWeight="SemiBold" Foreground="#1A1A2E"/>
                <ComboBox x:Name="cmbType" Grid.Column="1" Margin="10,0,20,0" 
                     SelectionChanged="FilterOrSortChanged" 
                     Style="{StaticResource {x:Static ToolBar.ComboBoxStyleKey}}"/>

                <!-- Фильтр по статусу -->
                <TextBlock Grid.Column="2" Text="Статус:" VerticalAlignment="Center" 
                      FontWeight="SemiBold" Foreground="#1A1A2E"/>
                <ComboBox x:Name="cmbStatus" Grid.Column="3" Margin="10,0,20,0" 
                     SelectionChanged="FilterOrSortChanged"/>

                <!-- Сортировка -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Сортировка:" VerticalAlignment="Center" 
                          FontWeight="SemiBold" Foreground="#1A1A2E" Margin="0,0,10,0"/>
                    <ComboBox x:Name="cmbSort" Width="180" SelectionChanged="FilterOrSortChanged">
                        <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                        <ComboBoxItem Content="Название (А-Я)"/>
                        <ComboBoxItem Content="Название (Я-А)"/>
                        <ComboBoxItem Content="Тип техники (А-Я)"/>
                        <ComboBoxItem Content="Тип техники (Я-А)"/>
                        <ComboBoxItem Content="Год производства (возрастание)"/>
                        <ComboBoxItem Content="Год производства (убывание)"/>
                    </ComboBox>
                </StackPanel>

                <!-- Кнопка сброса -->
                <Button Grid.Column="7" x:Name="btnReset" Content="Сбросить" 
                   Margin="20,0,0,0" Padding="15,8" Background="#E94560" 
                   Foreground="White" BorderThickness="0" Click="btnReset_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                               CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- DataGrid -->
            <Border Grid.Row="2" Background="White" Margin="20,0,20,20" CornerRadius="12">
                <DataGrid x:Name="dgEquipment" 
                     AutoGenerateColumns="False" 
                     IsReadOnly="True" 
                     SelectionMode="Single"
                     GridLinesVisibility="None"
                     BorderThickness="0"
                     RowBackground="White"
                     AlternatingRowBackground="#F8F9FA"
                     HeadersVisibility="Column">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F1F3F4"/>
                            <Setter Property="Foreground" Value="#1A1A2E"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="15,12"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="50"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E8F4F8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Инв. номер" Binding="{Binding InventoryNumber}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="15,0"/>
                                    <Setter Property="Foreground" Value="#5F6368"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Название - кликабельное -->
                        <DataGridTemplateColumn Header="Название техники" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" 
                                          VerticalAlignment="Center"
                                          Margin="15,0"
                                          FontWeight="SemiBold"
                                          Foreground="#0F3460"
                                          Cursor="Hand"
                                          TextDecorations="Underline">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#E94560"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.InputBindings>
                                            <MouseBinding Gesture="LeftClick" 
                                                   Command="{Binding DataContext.OpenDetailsCommand, 
                                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                   CommandParameter="{Binding}"/>
                                        </TextBlock.InputBindings>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Тип" Binding="{Binding EquipmentTypes.TypeName}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="15,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Год" Binding="{Binding ProductionYear}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="15,0"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Вес, т" Binding="{Binding Weight}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="15,0"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Экипаж" Binding="{Binding Crew}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="15,0"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Скорость" Binding="{Binding MaxSpeed, StringFormat={}{0} км/ч}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="15,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Статус" Binding="{Binding EquipmentStatus.StatusName}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="15,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EquipmentStatus.StatusName}" Value="Представлен">
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EquipmentStatus.StatusName}" Value="В ремонте">
                                            <Setter Property="Foreground" Value="#E94560"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EquipmentStatus.StatusName}" Value="На хранении">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EquipmentStatus.StatusName}" Value="На реставрации">
                                            <Setter Property="Foreground" Value="#8B5CF6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Кнопки действий -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20">
                <Button x:Name="btnAdd" Content="&#10133; Добавить" 
                   Padding="20,12" Margin="0,0,10,0" Background="#16A34A" 
                   Foreground="White" BorderThickness="0" Click="btnAdd_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                               CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                

                <Button x:Name="btnClose" Content="Закрыть" 
                   Padding="20,12" Background="#6B7280" 
                   Foreground="White" BorderThickness="0" Click="btnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                               CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Window>