<Window x:Class="FilichevKurs.View.Windowss.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FilichevKurs.View.Windowss"
        mc:Ignorable="d"
        Title="LoginWindow" Height="900" Width="1500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Центральная карточка -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="16" 
                Padding="40" 
                Margin="30"
                Width="900">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" 
                                BlurRadius="20" 
                                Opacity="0.3" 
                                Color="#000000"/>
            </Border.Effect>

            <StackPanel>
                <!-- Логотип -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Border Width="80" 
                           Height="80" 
                           CornerRadius="40" 
                           Background="#E94560"
                           Margin="0,0,0,16">
                        <TextBlock Text="&#9876;" 
                                  FontSize="40" 
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="ПАРК ТЕХНИКИ ВС РФ" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#1A1A2E"
                              TextAlignment="Center"/>
                    <TextBlock Text="Музей современной военной техники" 
                              FontSize="11" 
                              Foreground="#5F6368"
                              TextAlignment="Center"
                              Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Заголовок формы -->
                <TextBlock Text="Вход в систему" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="#1A1A2E"
                          Margin="0,0,0,24"/>

                <!-- Поле логин -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Email" 
                              FontSize="12" 
                              FontWeight="SemiBold"
                              Foreground="#5F6368"
                              Margin="0,0,0,6"/>
                    <Border BorderBrush="#E5E7EB" 
                           BorderThickness="1" 
                           CornerRadius="8"
                           Background="#F9FAFB">
                        <TextBox x:Name="txtLogin" 
                                BorderThickness="0"
                                Background="Transparent"
                                Padding="12,10"
                                FontSize="14"/>
                    </Border>
                </StackPanel>

                <!-- Поле пароль -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Пароль" 
                              FontSize="12" 
                              FontWeight="SemiBold"
                              Foreground="#5F6368"
                              Margin="0,0,0,6"/>
                    <Border BorderBrush="#E5E7EB" 
                           BorderThickness="1" 
                           CornerRadius="8"
                           Background="#F9FAFB">
                        <PasswordBox x:Name="txtPassword" 
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Padding="12,10"
                                    FontSize="14"/>
                    </Border>
                </StackPanel>

                <!-- Ошибка -->
                <TextBlock x:Name="txtError" 
                          Foreground="#E94560"
                          FontSize="12"
                          TextWrapping="Wrap"
                          Margin="0,8,0,16"
                          Visibility="Collapsed"/>

                <!-- Кнопка входа -->
                <Button x:Name="btnLogin" 
                       Content="Войти" 
                       Click="btnLogin_Click"
                       Background="#E94560"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Padding="0,12"
                       BorderThickness="0"
                       Cursor="Hand"
                       Margin="0,0,0,12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                   CornerRadius="8"
                                   Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D63D56"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Разделитель -->
                <Grid Margin="0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#E5E7EB" Height="1"/>
                    <TextBlock Grid.Column="1" 
                              Text="или" 
                              FontSize="12"
                              Foreground="#9CA3AF"
                              Margin="12,0"/>
                    <Border Grid.Column="2" Background="#E5E7EB" Height="1"/>
                </Grid>

                <!-- Кнопка регистрации -->
                <Button x:Name="btnRegister" 
                       Content="Создать аккаунт" 
                       Click="btnRegister_Click"
                       Background="Transparent"
                       Foreground="#0F3460"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Padding="0,12"
                       BorderBrush="#0F3460"
                       BorderThickness="1"
                       Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                   BorderBrush="{TemplateBinding BorderBrush}"
                                   BorderThickness="{TemplateBinding BorderThickness}"
                                   CornerRadius="8"
                                   Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F0F7FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>

        <!-- Фоновый декор -->
        <Canvas Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="-1" Opacity="0.1">
            <TextBlock Canvas.Left="50" Canvas.Top="100" 
                      Text="&#128737;" FontSize="200" Foreground="White"/>
            <TextBlock Canvas.Right="50" Canvas.Bottom="100" 
                      Text="&#9992;" FontSize="150" Foreground="White"/>
        </Canvas>
    </Grid>
</Window>