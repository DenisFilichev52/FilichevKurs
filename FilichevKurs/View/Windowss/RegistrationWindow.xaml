<Window x:Class="FilichevKurs.View.Windowss.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FilichevKurs.View.Windowss"
        mc:Ignorable="d"
        Title="RegistrationWindow" Height="1000" Width="1500">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="800"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Центральная карточка -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="16" 
                Padding="40" 
                Margin="30"
                MaxHeight="700" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0"/>
                    <RotateTransform/>
                    <TranslateTransform X="0"/>
                </TransformGroup>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" 
                                BlurRadius="20" 
                                Opacity="0.3" 
                                Color="#000000"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Шапка -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border Width="60" 
                               Height="60" 
                               CornerRadius="30" 
                               Background="#16A34A"
                               Margin="0,0,0,12">
                            <TextBlock Text="&#128100;" 
                                      FontSize="28" 
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Создание аккаунта" 
                                  FontSize="24" 
                                  FontWeight="Bold" 
                                  Foreground="#1A1A2E"
                                  TextAlignment="Center"/>
                        <TextBlock Text="Заполните данные для регистрации" 
                                  FontSize="12" 
                                  Foreground="#5F6368"
                                  TextAlignment="Center"
                                  Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Фамилия -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Фамилия *" 
                                  FontSize="12" 
                                  FontWeight="SemiBold"
                                  Foreground="#5F6368"
                                  Margin="0,0,0,6"/>
                        <Border BorderBrush="#E5E7EB" 
                               BorderThickness="1" 
                               CornerRadius="8"
                               Background="#F9FAFB">
                            <TextBox x:Name="txtLastName" 
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Padding="12,10"
                                    FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Имя -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Имя *" 
                                  FontSize="12" 
                                  FontWeight="SemiBold"
                                  Foreground="#5F6368"
                                  Margin="0,0,0,6"/>
                        <Border BorderBrush="#E5E7EB" 
                               BorderThickness="1" 
                               CornerRadius="8"
                               Background="#F9FAFB">
                            <TextBox x:Name="txtFirstName" 
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Padding="12,10"
                                    FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Отчество -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Отчество" 
                                  FontSize="12" 
                                  FontWeight="SemiBold"
                                  Foreground="#5F6368"
                                  Margin="0,0,0,6"/>
                        <Border BorderBrush="#E5E7EB" 
                               BorderThickness="1" 
                               CornerRadius="8"
                               Background="#F9FAFB">
                            <TextBox x:Name="txtMiddleName" 
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Padding="12,10"
                                    FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Дата рождения -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Дата рождения" 
                                  FontSize="12" 
                                  FontWeight="SemiBold"
                                  Foreground="#5F6368"
                                  Margin="0,0,0,6"/>
                        <Border BorderBrush="#E5E7EB" 
                               BorderThickness="1" 
                               CornerRadius="8"
                               Background="#F9FAFB"
                               Padding="4">
                            <DatePicker x:Name="dpBirthDate" 
                                       BorderThickness="0"
                                       Background="Transparent"
                                       FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Телефон -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Телефон *" 
                                  FontSize="12" 
                                  FontWeight="SemiBold"
                                  Foreground="#5F6368"
                                  Margin="0,0,0,6"/>
                        <Border BorderBrush="#E5E7EB" 
                               BorderThickness="1" 
                               CornerRadius="8"
                               Background="#F9FAFB">
                            <TextBox x:Name="txtPhone" 
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Padding="12,10"
                                    FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Email (логин) *" 
                                  FontSize="12" 
                                  FontWeight="SemiBold"
                                  Foreground="#5F6368"
                                  Margin="0,0,0,6"/>
                        <Border BorderBrush="#E5E7EB" 
                               BorderThickness="1" 
                               CornerRadius="8"
                               Background="#F9FAFB">
                            <TextBox x:Name="txtEmail" 
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Padding="12,10"
                                    FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Паспорт -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Номер паспорта" 
                                  FontSize="12" 
                                  FontWeight="SemiBold"
                                  Foreground="#5F6368"
                                  Margin="0,0,0,6"/>
                        <Border BorderBrush="#E5E7EB" 
                               BorderThickness="1" 
                               CornerRadius="8"
                               Background="#F9FAFB">
                            <TextBox x:Name="txtPassport" 
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Padding="12,10"
                                    FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Сообщение -->
                    <TextBlock x:Name="txtMessage" 
                              FontSize="12"
                              TextWrapping="Wrap"
                              Margin="0,0,0,16"
                              Visibility="Collapsed"/>

                    <!-- Кнопка регистрации -->
                    <Button x:Name="btnRegister" 
                           Content="Зарегистрироваться" 
                           Click="btnRegister_Click"
                           Background="#16A34A"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Padding="0,12"
                           BorderThickness="0"
                           Cursor="Hand"
                           Margin="0,0,0,12">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                       CornerRadius="8"
                                       Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#15803D"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Кнопка отмены -->
                    <Button x:Name="btnCancel" 
                           Content="Отмена" 
                           Click="btnCancel_Click"
                           Background="Transparent"
                           Foreground="#6B7280"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Padding="0,12"
                           BorderThickness="0"
                           Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                       CornerRadius="8"
                                       Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#374151"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Фоновый декор -->
        <Canvas Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="-1" Opacity="0.1">
            <TextBlock Canvas.Left="30" Canvas.Top="50" 
                      Text="&#128737;" FontSize="120" Foreground="White"/>
            <TextBlock Canvas.Right="40" Canvas.Bottom="80" 
                      Text="&#9992;" FontSize="100" Foreground="White"/>
            <TextBlock Canvas.Right="60" Canvas.Top="100" 
                      Text="&#128674;" FontSize="80" Foreground="White"/>
        </Canvas>
    </Grid>
</Window>
    