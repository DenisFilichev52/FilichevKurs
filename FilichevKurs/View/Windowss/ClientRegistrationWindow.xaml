<Window x:Class="FilichevKurs.View.Windowss.ClientRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FilichevKurs.View.Windowss"
        mc:Ignorable="d"
        Title="ClientRegistrationWindow" Height="900" Width="1500">
    <Grid>
        <Border Background="White" 
                CornerRadius="16" 
                Padding="30" 
                Margin="30"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" 
                                BlurRadius="20" 
                                Opacity="0.3"/>
            </Border.Effect>

            <StackPanel>
                <!-- Заголовок -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border Width="60" 
                           Height="60" 
                           CornerRadius="30" 
                           Background="#16A34A"
                           Margin="0,0,0,12">
                        <TextBlock Text="&#128100;" 
                                  FontSize="28" 
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="РЕГИСТРАЦИЯ КЛИЕНТА" 
                              FontSize="20" 
                              FontWeight="Bold" 
                              Foreground="#1A1A2E"
                              TextAlignment="Center"/>
                    <TextBlock Text="Выберите клиента и мероприятие" 
                              FontSize="12" 
                              Foreground="#5F6368"
                              TextAlignment="Center"
                              Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Выбор клиента -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Клиент (ФИО) *" 
                              FontSize="12" 
                              FontWeight="SemiBold"
                              Foreground="#5F6368"
                              Margin="0,0,0,6"/>
                    <ComboBox x:Name="cmbClient" 
                             DisplayMemberPath="FullName"
                             SelectedValuePath="ClientID"
                             FontSize="14"
                             Padding="8"
                             BorderBrush="#E5E7EB"/>
                </StackPanel>

                <!-- Или ввод ФИО вручную -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Или введите ФИО вручную" 
                              FontSize="12" 
                              FontWeight="SemiBold"
                              Foreground="#5F6368"
                              Margin="0,0,0,6"/>
                    <Border BorderBrush="#E5E7EB" 
                           BorderThickness="1" 
                           CornerRadius="8"
                           Background="#F9FAFB">
                        <TextBox x:Name="txtFullName" 
                                BorderThickness="0"
                                Background="Transparent"
                                Padding="12,10"
                                FontSize="14"
                                TextChanged="txtFullName_TextChanged"/>
                    </Border>
                </StackPanel>

                <!-- Выбор мероприятия -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Мероприятие *" 
                              FontSize="12" 
                              FontWeight="SemiBold"
                              Foreground="#5F6368"
                              Margin="0,0,0,6"/>
                    <ComboBox x:Name="cmbEvent" 
                             DisplayMemberPath="EventInfo"
                             SelectedValuePath="EventID"
                             FontSize="14"
                             Padding="8"
                             BorderBrush="#E5E7EB"/>
                </StackPanel>

                <!-- Информация о выбранном -->
                <Border x:Name="borderInfo" 
                       Background="#F9FAFB" 
                       CornerRadius="8" 
                       Padding="16"
                       Margin="0,0,0,16"
                       Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="txtSelectedEvent" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  Foreground="#1A1A2E"/>
                        <TextBlock x:Name="txtEventDate" 
                                  FontSize="12" 
                                  Foreground="#5F6368"
                                  Margin="0,4,0,0"/>
                        <TextBlock x:Name="txtEventPrice" 
                                  FontSize="12" 
                                  Foreground="#5F6368"/>
                    </StackPanel>
                </Border>

                <!-- Сообщение -->
                <TextBlock x:Name="txtMessage" 
                          FontSize="12"
                          TextWrapping="Wrap"
                          Margin="0,0,0,16"
                          Visibility="Collapsed"/>

                <!-- Кнопка записать -->
                <Button x:Name="btnRegister" 
                       Content="Записать на мероприятие" 
                       Click="btnRegister_Click"
                       Background="#16A34A"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Padding="0,12"
                       BorderThickness="0"
                       Cursor="Hand"
                       Margin="0,0,0,12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                   CornerRadius="8"
                                   Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#15803D"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#9CA3AF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Кнопка отмены -->
                <Button x:Name="btnCancel" 
                       Content="Отмена" 
                       Click="btnCancel_Click"
                       Background="Transparent"
                       Foreground="#6B7280"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Padding="0,12"
                       BorderThickness="0"
                       Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                   CornerRadius="8"
                                   Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#374151"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
