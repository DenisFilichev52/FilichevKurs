<Window x:Class="FilichevKurs.View.Windowss.MainWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FilichevKurs.View.Windowss"
        mc:Ignorable="d"
        Title="MainWin" Height="900" Width="1500">

        <Window.Resources>
            <!-- Современные цвета -->
            <SolidColorBrush x:Key="DarkColor" Color="#1A1A2E"/>
            <SolidColorBrush x:Key="PrimaryColor" Color="#16213E"/>
            <SolidColorBrush x:Key="AccentColor" Color="#0F3460"/>
            <SolidColorBrush x:Key="HighlightColor" Color="#E94560"/>
            <SolidColorBrush x:Key="LightGray" Color="#F1F3F4"/>
            <SolidColorBrush x:Key="TextGray" Color="#5F6368"/>

            <!-- Стиль для кнопок навигации -->
            <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="20,12"/>
                <Setter Property="Margin" Value="4,0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#E94560"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Стиль для активной кнопки -->
            <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
                <Setter Property="Background" Value="#E94560"/>
            </Style>

            <!-- Стиль для карточек контента -->
            <Style x:Key="ContentCard" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="24"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.1" Color="#000000"/>
                    </Setter.Value>
                </Setter>
            </Style>
        </Window.Resources>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель с логотипом и пользователем -->
            <Grid Grid.Row="0" Background="#1A1A2E" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="24,0">
                <TextBlock Text="&#9876;" FontSize="28" Foreground="#E94560" 
                          VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ПАРК ТЕХНИКИ ВС РФ" FontSize="16" 
                              FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Музей современной военной техники" 
                              FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Пользователь -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="24,0">
                    <Border Width="36" Height="36" CornerRadius="18" 
                       Background="#E94560" Margin="0,0,12,0">
                        <TextBlock x:Name="txtUserInitial" 
                              Foreground="White" FontSize="16" FontWeight="Bold"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtUserName" FontSize="13" 
                              Foreground="White" FontWeight="Medium"/>
                        <TextBlock x:Name="txtUserRole" FontSize="11" 
                              Foreground="#888"/>
                    </StackPanel>
                    <Button x:Name="btnLogout" Content="&#10148;" 
                       Foreground="#E94560" Background="Transparent" 
                       BorderThickness="0" FontSize="18" Margin="16,0,0,0" 
                       Click="btnLogout_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- Горизонтальное меню навигации -->
            <Border Grid.Row="1" Background="#16213E" Padding="16,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="btnHome" Content="&#8962; Главная" 
                       Style="{StaticResource NavButtonActive}" Click="btnHome_Click"/>
                    <Button x:Name="btnEquipment" Content="&#128737; Техника" 
                       Style="{StaticResource NavButton}" Click="btnEquipment_Click"/>
                    <Button x:Name="btnEvents" Content="&#127881; Мероприятия" 
                       Style="{StaticResource NavButton}" Click="btnEvents_Click"/>
                    <Button x:Name="btnProfile" Content="&#128100; Профиль" 
                       Style="{StaticResource NavButton}" Click="btnProfile_Click"/>
                    
                </StackPanel>
            </Border>

            <!-- Основной контент -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Grid Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Приветственная секция -->
                    <Border Grid.Row="0" Style="{StaticResource ContentCard}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Добро пожаловать!" FontSize="32" 
                                      FontWeight="Bold" Foreground="#1A1A2E" Margin="0,0,0,8"/>
                                <TextBlock x:Name="txtWelcome" FontSize="16" 
                                      Foreground="#5F6368" TextWrapping="Wrap" MaxWidth="600" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Просмотреть технику" 
                                       Background="#E94560" Foreground="White" 
                                       Padding="20,12" FontSize="14" 
                                       FontWeight="SemiBold" BorderThickness="0" 
                                       Click="btnEquipment_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                   CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="Афиша мероприятий" 
                                       Background="Transparent" Foreground="#E94560" 
                                       Padding="20,12" FontSize="14" FontWeight="SemiBold" 
                                       BorderThickness="2" BorderBrush="#E94560" 
                                       Margin="12,0,0,0" Click="btnEvents_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                   BorderBrush="{TemplateBinding BorderBrush}" 
                                                   BorderThickness="{TemplateBinding BorderThickness}" 
                                                   CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                            <Border Grid.Column="1" Width="200" Height="200" 
                               CornerRadius="100" Background="#F1F3F4" Margin="40,0,0,0">
                                <TextBlock Text="&#128737;" FontSize="100" 
                                      Foreground="#E94560" HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Заголовок быстрый доступ -->
                    <TextBlock Grid.Row="1" Text="Быстрый доступ" FontSize="20" FontWeight="Bold" 
                          Foreground="#1A1A2E" Margin="0,24,0,16"/>

                    <!-- Быстрые действия -->
                    <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,16">
                        <!-- Карточка 1 -->
                        <Border Style="{StaticResource ContentCard}" Margin="8" 
                           MouseLeftButtonUp="btnEquipment_Click" Cursor="Hand">
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="12" 
                                   Background="#FFF5F5" Margin="0,0,0,12">
                                    <TextBlock Text="&#128737;" FontSize="24" Foreground="#E94560" HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                            </Border>
                                <TextBlock Text="Каталог техники" FontSize="16" 
                                      FontWeight="Bold" Foreground="#1A1A2E"/>
                                <TextBlock Text="Танки, самолеты, вертолеты" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Карточка 2 -->
                        <Border Style="{StaticResource ContentCard}" Margin="8" 
                           MouseLeftButtonUp="btnEvents_Click" Cursor="Hand">
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="12" 
                                   Background="#F0F7FF" Margin="0,0,0,12">
                                    <TextBlock Text="&#127881;" FontSize="24" 
                                          Foreground="#0F3460" HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Мероприятия" FontSize="16" 
                                      FontWeight="Bold" Foreground="#1A1A2E"/>
                                <TextBlock Text="Аэрошоу и танковый биатлон" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Карточка 3 -->
                        <Border Style="{StaticResource ContentCard}" Margin="8" 
                           MouseLeftButtonUp="btnProfile_Click" Cursor="Hand">
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="12" 
                                   Background="#F5FFF5" Margin="0,0,0,12">
                                    <TextBlock Text="&#128100;" FontSize="24" 
                                          Foreground="#16A34A" HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Мой профиль" FontSize="16" 
                                      FontWeight="Bold" Foreground="#1A1A2E"/>
                                <TextBlock Text="История и настройки" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Карточка 4 -->
                        <Border x:Name="cardStats" Style="{StaticResource ContentCard}" Margin="8" 
                           MouseLeftButtonUp="btnStats_Click" Cursor="Hand">
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="12" 
                                   Background="#FFFBF0" Margin="0,0,0,12">
                                    <TextBlock Text="&#128202;" FontSize="24" 
                                          Foreground="#F59E0B" HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Статистика" FontSize="16" 
                                      FontWeight="Bold" Foreground="#1A1A2E"/>
                                <TextBlock Text="Отчеты и аналитика" 
                                      FontSize="12" Foreground="#5F6368" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Заголовок статистика -->
                <TextBlock Grid.Row="3" Text="Парк в цифрах" FontSize="20" FontWeight="Bold" 
                          Foreground="#1A1A2E" Margin="0,24,0,16"/>
                <!-- Статистика в цифрах -->
                    <UniformGrid Grid.Row="4" Columns="4" Margin="0,0,0,32">
                        <Border Background="#E94560" CornerRadius="12" Padding="20" Margin="8">
                            <StackPanel>
                                <TextBlock Text="50+" FontSize="36" FontWeight="Bold" 
                                      Foreground="White"/>
                                <TextBlock Text="Единиц техники" FontSize="14" 
                                      Foreground="#FFCCCB" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0F3460" CornerRadius="12" Padding="20" Margin="8">
                            <StackPanel>
                                <TextBlock Text="12" FontSize="36" FontWeight="Bold" 
                                      Foreground="White"/>
                                <TextBlock Text="Типов вооружения" FontSize="14" 
                                      Foreground="#B0C4DE" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#16A34A" CornerRadius="12" Padding="20" Margin="8">
                            <StackPanel>
                                <TextBlock Text="100+" FontSize="36" FontWeight="Bold" 
                                      Foreground="White"/>
                                <TextBlock Text="Мероприятий в год" FontSize="14" 
                                      Foreground="#90EE90" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F59E0B" CornerRadius="12" Padding="20" Margin="8">
                            <StackPanel>
                                <TextBlock Text="50K+" FontSize="36" FontWeight="Bold" 
                                      Foreground="White"/>
                                <TextBlock Text="Посетителей" FontSize="14" 
                                      Foreground="#FFE4B5" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                </Grid>
            </ScrollViewer>
        </Grid>
    </Window>