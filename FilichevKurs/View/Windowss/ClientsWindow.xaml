<Window x:Class="FilichevKurs.View.Windowss.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FilichevKurs.View.Windowss"
        mc:Ignorable="d"
       Title="Клиенты" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Шапка -->
        <Border Background="#1A237E" Height="50" VerticalAlignment="Top">
            <Grid>
                <TextBlock Text="БАЗА КЛИЕНТОВ" 
                           Foreground="White" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="15,0"/>

                <Button Content="+ Добавить" 
                        Background="#E91E63"
                        Foreground="White"
                        Padding="15,8"
                        HorizontalAlignment="Right"
                        Margin="0,0,15,0"
                        Click="AddButton_Click"/>
            </Grid>
        </Border>

        <!-- Список -->
        <DataGrid x:Name="dgClients" 
                  Margin="0,50,0,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ClientID}" Width="50"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="120"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="120"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
